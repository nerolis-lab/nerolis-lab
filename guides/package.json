    "typescript": "^5.9.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress": "2.0.0-alpha.18",
    "vitest": "^3.2.7",
    "vue": "^3.5.39",
    "vuetify": "^4.1.5"
