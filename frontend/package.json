{
  "name": "sleepapi-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "dev": "vite --host",
    "clean": "rimraf dist",
    "prebuild": "npm install && npm run clean",
    "build": "run-p type-check build-only",
    "build-only": "vite build",
    "preview": "vite preview",
    "test": "vitest --run --coverage",
    "test-watch": "vitest --watch",
    "type-check": "vue-tsc --build --force",
    "type-watch": "vue-tsc --noEmit --watch",
    "vuetify-mcp": "npx -y @vuetify/mcp"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@mdi/font": "^7.4.47",
    "axios": "^1.15.0",
    "axios-mock-adapter": "^2.1.0",
    "chart.js": "^4.5.1",
    "modern-screenshot": "^4.6.8",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.9",
    "@types/html2canvas": "^1.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "@vuetify/mcp": "^0.6.0",
    "fs-extra": "^11.3.4",
    "html2canvas": "^1.4.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "resize-observer-polyfill": "^1.5.1",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "sleepapi-common": "file:../common",
    "typescript": "^6.0.2",
    "vimic": "^1.2.4",
    "vite": "^7.3.2",
    "vite-plugin-csp-guard": "^3.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.4",
    "vitest-canvas-mock": "^1.1.4",
    "vue-tsc": "^3.2.6",
    "vuetify": "^4.0.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  },
  "bundleDependencies": ["sleepapi-common"]
